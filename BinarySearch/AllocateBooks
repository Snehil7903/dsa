Allocate Books (GeeksForGeeks) / Split Array Largest Sum (LC 410)

class Solution {
    public int splitArray(int[] nums, int k) {
        int low = 0, high = 0;
        for (int n : nums) {
            low = Math.max(low, n); // Max single element
            high += n;              // Sum of all elements
        }
        int ans = high;
        while (low <= high) {
            int mid = low + (high - low) / 2;
            if (canSplit(nums, k, mid)) {
                ans = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }
        return ans;
    }

    private boolean canSplit(int[] nums, int k, int maxCapacity) {
        int currentSum = 0, subarrays = 1;
        for (int n : nums) {
            if (currentSum + n > maxCapacity) {
                subarrays++;
                currentSum = n;
                if (subarrays > k) return false;
            } else {
                currentSum += n;
            }
        }
        return true;
    }
}
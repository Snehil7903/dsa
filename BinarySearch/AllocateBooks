Allocate Books (GeeksForGeeks) / Split Array Largest Sum (LC 410)


Template:-
public long solve(int[] data, int constraint) {
    long low = MIN_POSSIBLE_VALUE; // Often 0 or 1
    long high = MAX_POSSIBLE_VALUE; // Often Sum of array or a large 10^18
    long ans = high;

    while (low <= high) {
        long mid = low + (high - low) / 2;

        if (check(mid, data, constraint)) {
            ans = mid;      // Mid is a candidate...
            high = mid - 1; // ...but let's see if we can go LOWER
        } else {
            low = mid + 1;  // Not enough, must go HIGHER
        }
    }
    return ans;
}

private boolean check(long mid, int[] data, int constraint) {
    // 1. If Sequential (Books/Koko): Can we finish under limit 'mid'?
    // 2. If Simultaneous (Mountain): How much work is done in time 'mid'?
    // 3. Return true/false.
}


class Solution {
    public int splitArray(int[] nums, int k) {
        int low = 0, high = 0;
        for (int n : nums) {
            low = Math.max(low, n); // Max single element
            high += n;              // Sum of all elements
        }
        int ans = high;
        while (low <= high) {
            int mid = low + (high - low) / 2;
            if (canSplit(nums, k, mid)) {
                ans = mid;
                high = mid - 1;
            } else {
                low = mid + 1;
            }
        }
        return ans;
    }

    private boolean canSplit(int[] nums, int k, int maxCapacity) {
        int currentSum = 0, subarrays = 1;
        for (int n : nums) {
            if (currentSum + n > maxCapacity) {
                subarrays++;
                currentSum = n;
                if (subarrays > k) return false;
            } else {
                currentSum += n;
            }
        }
        return true;
    }
}
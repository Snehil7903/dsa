Binary Exponentiation (Fast Power)

It computes:a^b % MOD
in:O(log b)
instead of:O(b)

 private long modPow(long a, long b){
        long ans =1;
        while(b>0){
            if((b&1)==1){
                ans = (ans*a)%MOD;
            }
            a = (a*a)%MOD;
            b>>=1;
        }
        return ans;
}


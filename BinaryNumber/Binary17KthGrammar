1545. Find Kth Bit in Nth Binary String

class Solution {
    public char findKthBit(int n, int k) {
        if (n == 1) return '0';
        int mid = 1 << (n - 1);
        if (k == mid) {
            return '1';
        } else if (k < mid) {
            return findKthBit(n - 1, k);
        } else {
            char res = findKthBit(n - 1, (mid * 2) - k);
            return (res == '0') ? '1' : '0';
        }
    }
}
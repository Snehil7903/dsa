import java.util.*;

class Solution {
    // Standard Trie Node structure
    static class TrieNode {
        TrieNode[] children = new TrieNode[26];
        String word = null; // Storing the full string at the leaf simplifies retrieval!
    }
    
    public List<String> findWords(char[][] board, String[] words) {
        List<String> result = new ArrayList<>();
        TrieNode root = buildTrie(words);
        
        int m = board.length;
        int n = board[0].length;
        
        // Run graph DFS from every cell on the board
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                dfs(board, i, j, root, result);
            }
        }
        
        return result;
    }
    
    private void dfs(char[][] board, int r, int c, TrieNode node, List<String> result) {
        int m = board.length;
        int n = board[0].length;
        
        // 1. Boundary & Tracking Guards
        if (r < 0 || c < 0 || r >= m || c >= n) return;
        
        char ch = board[r][c];
        if (ch == '#') return; // '#' represents a cell visited on the current DFS path
        
        // 2. Trie Step Evaluation
        TrieNode nextNode = node.children[ch - 'a'];
        if (nextNode == null) return; // If this character doesn't help spell any word, prune!
        
        // 3. Match Detection
        if (nextNode.word != null) {
            result.add(nextNode.word);
            nextNode.word = null; // De-duplicate: prevents adding the same word multiple times
        }
        
        // 4. Backtracking Graph Step
        board[r][c] = '#'; // Mark cell as visited
        
        dfs(board, r + 1, c, nextNode, result);
        dfs(board, r, c + 1, nextNode, result);
        dfs(board, r - 1, c, nextNode, result);
        dfs(board, r, c - 1, nextNode, result);
        
        board[r][c] = ch; // Restore cell value upon return
    }
    
    // Helper to insert dictionary words into the Trie
    private TrieNode buildTrie(String[] words) {
        TrieNode root = new TrieNode();
        for (String w : words) {
            TrieNode curr = root;
            for (char c : w.toCharArray()) {
                int idx = c - 'a';
                if (curr.children[idx] == null) {
                    curr.children[idx] = new TrieNode();
                }
                curr = curr.children[idx];
            }
            curr.word = w; // Set the word at the final terminating node
        }
        return root;
    }
}
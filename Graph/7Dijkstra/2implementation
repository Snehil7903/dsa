}

int[] dist;

Arrays.fill(dist, INF);

dist[source] = 0;

PriorityQueue<State> pq =new PriorityQueue<>((a,b)->a.distance-b.distance);

while(!pq.isEmpty()){

State current = pq.poll();
    int node = current.node;
    int distance = current.distance;

    // Is this entry outdated?
    if(distance>dist[node]) continue;

    for(Edge edge : graph.get(current.node)){

        int neighbor = edge.to;
        int weight = edge.weight;

        if(dist[neighbor] > dist[current.node] + weight){

            int newDistance = dist[current.node] + weight;

            dist[neighbor] = newDistance;

            pq.offer(new State(neighbor,newDistance));

        }
    }

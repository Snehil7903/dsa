import java.util.*;

class Solution {
    public List<String> findPermutations(String s) {
        List<String> result = new ArrayList<>();
        // Convert to char array so we can swap in-place
        solve(s.toCharArray(), 0, result);
        return result;
    }

    private void solve(char[] chars, int index, List<String> result) {
        // Base Case: If index reaches the end, we have a complete permutation
        if (index == chars.length) {
            result.add(new String(chars));
            return;
        }

        for (int i = index; i < chars.length; i++) {
            // 1. Action: Swap the current index with the i-th character
            swap(chars, index, i);

            // 2. Recurse: Fix the next position
            solve(chars, index + 1, result);

            // 3. Backtrack: Swap back to restore original state
            swap(chars, index, i);
        }
    }

    private void swap(char[] chars, int i, int j) {
        char temp = chars[i];
        chars[i] = chars[j];
        chars[j] = temp;
    }
}
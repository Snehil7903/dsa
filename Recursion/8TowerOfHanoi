class Solution {
    public void solve(int n, char s, char d, char h) {
        // Base Case: If there's only one plate, move it directly
        if (n == 1) {
            System.out.println("Move plate " + n + " from " + s + " to " + d);
            return;
        }

        // Step 1: Move n-1 plates from Source (s) to Helper (h)
        // We use the Destination (d) as our temporary rod
        solve(n - 1, s, h, d);

        // Step 2: Move the nth (largest) plate from Source (s) to Destination (d)
        System.out.println("Move plate " + n + " from " + s + " to " + d);

        // Step 3: Move the n-1 plates from Helper (h) to Destination (d)
        // We use the Source (s) as our temporary rod
        solve(n - 1, h, d, s);
    }

    public static void main(String[] args) {
        Solution sol = new Solution();
        // Move 3 plates from rod A to rod C using B as helper
        sol.solve(3, 'A', 'C', 'B');
    }
}
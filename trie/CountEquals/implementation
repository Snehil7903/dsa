public int countWordsEqualTo(String word) {

    TrieNode curr = root;

    for(char ch : word.toCharArray()) {

        int idx = ch - 'a';

        if(curr.children[idx] == null)
            return 0;

        curr = curr.children[idx];
    }

    return curr.endCount;
}

